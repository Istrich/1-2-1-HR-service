# === Обязательные ===
# Пользователи (формат: user1:pass1,user2:pass2)
USERS=admin:changeme,hr_manager:securepass123

# Ключи ИИ (нужен хотя бы один сценарий: см. ниже)
# — для транскрипции через OpenAI API: OPENAI_API_KEY
# — для отчёта/письма через OpenAI: OPENAI_API_KEY + REPORT_AI_PROVIDER=openai
# — для отчёта/письма через DeepSeek: DEEPSEEK_API_KEY + REPORT_AI_PROVIDER=deepseek
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# === Опциональные ===
SECRET_KEY=your-random-secret-key-for-jwt
JWT_EXPIRE_HOURS=24

# Отчёт и письмо: openai | deepseek
REPORT_AI_PROVIDER=openai
# Модель OpenAI для отчёта (chat completions)
OPENAI_REPORT_MODEL=gpt-4o
# Модель DeepSeek
DEEPSEEK_MODEL=deepseek-chat

# Транскрипция: local (openai-whisper на машине) или api (OpenAI whisper-1)
WHISPER_BACKEND=local
WHISPER_MODEL=small
